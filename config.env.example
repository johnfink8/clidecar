# Claude sidecar configuration. Copy to config.env, edit, then `clidecar recycle`
# to apply (workdir/param changes take effect on the next launch).
# config.env is gitignored — your real values never get committed.

# --- how the managed Claude is launched ---
WORKDIR="$HOME/clidecar"                 # dir the managed Claude runs in
CLAUDE_BIN="$HOME/.local/bin/claude"     # path to the claude CLI (or just "claude" if on PATH)
SCREEN_NAME="clidecar"
# Extra args passed to claude at launch. Both of these are OPTIONAL add-ons —
# clidecar itself is just the harness; mix in what you want:
#   --dangerously-load-development-channels server:clidecar   attach clidecar's own
#       gateway as the inbound channel (pair with GATEWAY_DAEMON=1 below; the shim
#       must be registered as the `clidecar` MCP server in ~/.claude.json)
#   --remote-control "clidecar"                               drive from claude.ai / mobile
# Keep --permission-mode auto: the auto-mode classifier is a security feature
# (see the README "Limitations" section) — we recommend leaving it on.
CLAUDE_ARGS="--permission-mode auto"

# --- gateway daemon (the inbound channel; optional) ---
# 1 = the supervisor keeps a persistent gateway daemon alive alongside Claude
# (owns the messaging-app connection + inbound routing; survives recycles).
# Requires the --dangerously-load-development-channels arg above. 0/unset = off.
GATEWAY_DAEMON="0"
# Interpreter for the gateway daemon — the uv venv, so its deps (croniter,
# holidays) resolve. `uv sync` in the repo builds .venv. Only used when the
# daemon is on; hooks + shim stay on the system python3.
PYTHON_BIN="$WORKDIR/.venv/bin/python"

# --- startup prompt ---
# Passed as claude's positional prompt at every (re)launch, so a fresh instance
# boots already thinking instead of idle. Expanded by the inner shell from the
# environment, so its text needs no escaping (avoid the chars $ ` \ and double
# quotes here, since config.env is shell-sourced). Leave empty to launch silent.
STARTUP_PROMPT="You just launched under the clidecar sidecar with a fresh context. Before anything else, orient yourself: read state/state.md and state/queue.md under WORKDIR, then recall from your durable memory store whatever bears on the current focus. Once oriented, post a short readiness note on the configured notification channel (if any) — back online and oriented, plus a one-line note on what state.md says to pick up next. Keep it brief, then wait."

# --- recycle / kill timing ---
GRACE_SECS=10            # SIGTERM grace before SIGKILL

# --- claude crash-loop guard (sidecar-internal; only counts unexpected deaths,
#     not deliberate recycles). systemd's StartLimit guards the sidecar itself. ---
MAX_RELAUNCHES=5         # more than this many crash-relaunches...
WINDOW_SECS=120          # ...within this window...
PAUSE_SECS=300           # ...triggers a pause + notification.

# --- event loop ---
POLL_SECS=5              # backstop tick; inotify gives instant flag response

# --- notifications (optional; used by bin/notify-discord.sh) ---
# The Discord bot token is read by NAME from ~/.claude/channels/discord/.env
# (DISCORD_BOT_TOKEN) and never stored here. Set your channel id below.
DISCORD_CHANNEL_ID=""    # e.g. 123456789012345678
