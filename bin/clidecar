#!/usr/bin/env bash
# clidecar — control the sidecar from inside the managed Claude session.
#
#   clidecar recycle           # reset my own context (checkpoint FIRST!)
#   clidecar set KEY VALUE     # edit config.env (e.g. WORKDIR) — apply with recycle
#   clidecar reload            # swap sidecar code without disturbing Claude
#   clidecar status            # systemd status of the sidecar
#   clidecar logs [N]          # last N journald lines (default 50)
#   clidecar down              # stop sidecar AND kill every managed agent
#   clidecar up                # (re)start the sidecar service
#   clidecar agent list|spawn|stop|start|remove|route|set|recycle [...]   # manage the fleet
#   clidecar plugin list|enable|disable [name]   # manage hook plugins (recycle to apply)
#   clidecar gateway reload|status|logs [N]      # manage the persistent gateway daemon
set -uo pipefail
# Resolve symlinks so invocation via ~/.local/bin/clidecar still points at the
# real repo (else CLIDECAR_HOME would be ~/.local and recycle flags land in a
# control dir the sidecar never watches).
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
CLIDECAR_HOME="$(cd "$(dirname "$SELF")/.." && pwd)"
# runtime/personal data lives outside the repo, in ~/.clidecar (fixed path so the
# CLI and the systemd-launched sidecar never disagree on where data lives)
CLIDECAR_DATA="$HOME/.clidecar"
CONTROL="$CLIDECAR_DATA/control"; mkdir -p "$CONTROL" "$CLIDECAR_DATA/known-good"
CONFIG_FILE="$CLIDECAR_DATA/config.env"

cmd="${1:-help}"; shift || true
case "$cmd" in
  recycle)
    # Agent-aware: from inside an agent's session CLIDECAR_AGENT_ID is set, so recycle just THAT
    # agent; from the console (no env) drop the global flag = recycle every enabled agent.
    if [ -n "${CLIDECAR_AGENT_ID:-}" ]; then
      mkdir -p "$CONTROL/agents/$CLIDECAR_AGENT_ID"
      touch "$CONTROL/agents/$CLIDECAR_AGENT_ID/RECYCLE"
      echo "RECYCLE dropped for agent '$CLIDECAR_AGENT_ID'. Checkpoint to state.md + memory FIRST —"
      echo "the sidecar will SIGTERM this session and relaunch it fresh."
    else
      touch "$CONTROL/RECYCLE"
      echo "RECYCLE (all agents) dropped. Checkpoint FIRST — every enabled agent is relaunched fresh."
    fi
    ;;
  agent)
    sub="${1:-list}"; shift || true
    FC="$CLIDECAR_HOME/bin/_fleetctl.py"
    case "$sub" in
      list|ls)  python3 "$FC" list ;;
      recycle)
        id="${1:?usage: clidecar agent recycle <id>}"
        mkdir -p "$CONTROL/agents/$id"; touch "$CONTROL/agents/$id/RECYCLE"
        echo "recycle flag dropped for agent '$id'." ;;
      spawn|add) python3 "$FC" add "$@" && echo "added to fleet — supervisor will launch it." ;;
      stop)      python3 "$FC" disable "$@" && echo "disabled — supervisor will stop it." ;;
      start)     python3 "$FC" enable "$@" && echo "enabled — supervisor will launch it." ;;
      remove)    python3 "$FC" remove "$@" && echo "removed from fleet." ;;
      route|set) python3 "$FC" set "$@" && echo "updated (applies on next relaunch)." ;;
      *) echo "usage: clidecar agent list|spawn|stop|start|remove|route|set|recycle [...]" >&2; exit 1 ;;
    esac
    ;;
  set)
    key="${1:?usage: clidecar set KEY VALUE}"; val="${2:?usage: clidecar set KEY VALUE}"
    # Keys must be shell identifiers — config.env is sourced, so a non-identifier
    # key could never be read back. Fail loud rather than write a line that breaks
    # sourcing later. (Also keeps the grep below regex-metachar-free.)
    if ! [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      echo "clidecar set: invalid key '$key' (must be a shell identifier)" >&2; exit 1
    fi
    # Escape for a double-quoted shell value: backslash, double-quote, and BACKTICK,
    # so the value round-trips literally while $HOME-style expansion still works
    # (config.env's contract — see config.env.example). Backticks are load-bearing:
    # config.env is sourced by sidecar.sh on every launch, so an unescaped
    # backtick command-substitutes on every source — a STARTUP_PROMPT containing
    # `clidecar gateway reload` once ran it in a loop and crash-bombed the supervisor.
    # $(...) still substitutes via the intentionally-live $; reject it below.
    # Written with printf into a rewritten file, never sed, so | & " and newlines
    # can't corrupt config.env the way the old sed `|`-delimiter substitution did.
    if [[ "$val" == *'$('* ]]; then
      echo "clidecar set: value contains \$( command substitution; refusing (use a literal value)" >&2; exit 1
    fi
    esc="${val//\\/\\\\}"; esc="${esc//\"/\\\"}"; esc="${esc//\`/\\\`}"
    tmp="$(mktemp "${CONFIG_FILE}.XXXXXX")" || { echo "clidecar set: mktemp failed" >&2; exit 1; }
    # Each write is checked before the atomic mv — a failed/partial rewrite must
    # NOT clobber the good config or report success (no set -e here, so rc must be
    # inspected explicitly). grep rc=1 means "no lines survived" (re-setting the
    # only key) — normal; rc>=2 is a real read error, so bail on that alone.
    if [ -f "$CONFIG_FILE" ]; then
      grep -vE "^${key}=" "$CONFIG_FILE" > "$tmp"
      [ "$?" -ge 2 ] && { echo "clidecar set: failed reading $CONFIG_FILE" >&2; rm -f "$tmp"; exit 1; }
    fi
    if ! printf '%s="%s"\n' "$key" "$esc" >> "$tmp"; then
      echo "clidecar set: failed writing temp file" >&2; rm -f "$tmp"; exit 1
    fi
    if ! mv "$tmp" "$CONFIG_FILE"; then
      echo "clidecar set: failed updating $CONFIG_FILE" >&2; rm -f "$tmp"; exit 1
    fi
    echo "set ${key}=\"${val}\". Run 'clidecar recycle' to apply."
    ;;
  reload)
    if ! bash -n "$CLIDECAR_HOME/bin/sidecar.sh"; then
      echo "sidecar.sh FAILED syntax check — not reloading." >&2; exit 1
    fi
    cp "$CLIDECAR_HOME/bin/sidecar.sh" "$CLIDECAR_DATA/known-good/sidecar.sh"
    systemctl --user restart clidecar
    echo "sidecar reloaded; Claude adopted (untouched); known-good updated."
    ;;
  status) systemctl --user status clidecar --no-pager || true ;;
  logs)   journalctl --user -u clidecar -n "${1:-50}" --no-pager || true ;;
  down)
    systemctl --user stop clidecar || true
    # teardown must finish even if config.env is missing — warn loudly, fall back
    # to defaults so we still kill claude and clean up rather than crashing midway.
    if [ -f "$CONFIG_FILE" ]; then
      . "$CONFIG_FILE"
    else
      echo "warning: $CONFIG_FILE not found — using defaults for teardown." >&2
    fi
    # Kill EVERY managed agent by PID — quitting a screen alone can leave claude orphaned (it
    # survives the SIGHUP), so signal each explicitly, then quit its screen.
    if [ -d "$CONTROL/agents" ]; then
      for d in "$CONTROL/agents"/*/; do
        [ -d "$d" ] || continue
        id="$(basename "$d")"
        p="$(cat "$d/claude.pid" 2>/dev/null || true)"
        if [ -n "$p" ] && kill -0 "$p" 2>/dev/null; then
          kill -TERM "$p" 2>/dev/null || true
          for _ in $(seq 1 "${GRACE_SECS:-10}"); do kill -0 "$p" 2>/dev/null || break; sleep 1; done
          kill -KILL "$p" 2>/dev/null || true
        fi
        screen -S "${SCREEN_NAME:-clidecar}-$id" -X quit >/dev/null 2>&1 || true
        rm -f "$d/claude.pid"
      done
    fi
    echo "sidecar stopped and all managed agents killed."
    ;;
  up)     systemctl --user start clidecar && echo "sidecar started." ;;
  plugin)
    sub="${1:-list}"; shift || true
    python3 "$CLIDECAR_HOME/bin/_pluginctl.py" "$CLIDECAR_HOME" "$sub" "$@"
    ;;
  gateway)
    # Manage the persistent gateway daemon. `reload` restarts the daemon (re-reads bridge/gateway.py
    # core), then recycles Claude so its MCP shim reattaches to the new broker socket — a bare daemon
    # restart strands inbound (the live shim can't reconnect a stdio server). The supervisor catches
    # the flag on its next loop. Costs a context reset: checkpoint first, same as `recycle`.
    sub="${1:-status}"; shift || true
    case "$sub" in
      reload)
        touch "$CONTROL/GATEWAY_RELOAD"
        echo "GATEWAY_RELOAD dropped — supervisor will restart the daemon AND recycle ALL agents so"
        echo "their shims reattach to the new socket. Checkpoint to state.md + memory FIRST (context resets)."
        ;;
      status)
        p="$(cat "$CONTROL/gateway.pid" 2>/dev/null || true)"
        if [ -n "$p" ] && kill -0 "$p" 2>/dev/null; then
          echo "gateway daemon running (pid=$p)"
        else
          echo "gateway daemon NOT running"
        fi
        ;;
      logs) tail -n "${1:-50}" "$CLIDECAR_DATA/state/gateway-daemon.log" 2>/dev/null || echo "(no gateway log yet)" ;;
      *) echo "usage: clidecar gateway reload|status|logs [N]" >&2; exit 1 ;;
    esac
    ;;
  *)
    grep -E '^#( |$)' "$0" | sed -E 's/^# ?//' | sed -n '2,20p'
    ;;
esac
